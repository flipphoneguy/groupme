# === GroupMe Utility Bot configuration ===
# Copy this file to ".env" and fill in what you need. Every value is optional —
# with none set, the bot still answers all utility commands (weather, stocks, etc.).

# (Optional) Your GroupMe API token — https://dev.groupme.com/applications
# Required for admin commands (-@, -add, -remove, -groups, -members) and the + Copilot feature.
GROUPME_TOKEN=

# (Optional) Your GroupMe user ID — the account allowed to run admin commands.
# See the README ("Finding your user ID") for how to get this.
ADMIN_UID=

# (Optional) Fallback token for the + Copilot feature.
# By default every + message is sent using GROUPME_TOKEN (your own account).
# Set this to a second account's token if you'd rather non-admin members'
# + messages be sent from that spare account instead of from your account.
FALLBACK_TOKEN=

# (Optional) Webhook auth code. If set, your callback URL must include ?auth=THIS_VALUE
# Leave empty to accept all incoming webhooks.
AUTH_CODE=
